{
  "name": "@hudak/tape-looper",
  "version": "0.1.0",
  "type": "module",
  "description": "Browser multitrack tape-machine DAW — record, overwrite, play back",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "clean": "rm -rf dist node_modules",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hudak/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tools/eslint-config": "workspace:*",
    "@tools/typescript-config": "workspace:*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
